# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<dbUser>:<dbPassword>@<cluster-url>/creditxplain?retryWrites=true&w=majority

# Authentication
JWT_SECRET=replace_with_a_long_random_secret

# ML Service
ML_SERVICE_URL=http://localhost:8000

# Frontend origin(s) for CORS
# Use comma-separated values for multiple origins in production
# Example: https://your-app.vercel.app,https://your-preview.vercel.app
CLIENT_URL=http://localhost:5173
